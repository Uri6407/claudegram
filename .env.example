# Используется в standalone-режиме (когда сервер запускается БЕЗ Claude Code).
# В режиме плагина значения берутся из userConfig (.claude-plugin/plugin.json),
# Claude Code сам прокидывает их в env как ${user_config.tg_*}.

# Получить на https://my.telegram.org → API development tools
TG_API_ID=
TG_API_HASH=

# Номер телефона в международном формате, например +79991234567
TG_PHONE=

# Имя session-файла. В standalone лежит в корне проекта (./<имя>.session).
# В плагин-режиме автоматически идёт в ${CLAUDE_PLUGIN_DATA}/<имя>.session
# и переживает апдейты плагина.
TG_SESSION_NAME=claudegram

# Опционально: облачный пароль 2FA, если включён.
# Можно оставить пустым — auth-скрипт спросит интерактивно.
TG_2FA_PASSWORD=

# Channel mode (опционально, для standalone-режима).
# Если 1 — сервер слушает входящие Telegram-сообщения и пушит в Claude
# как notifications/claude/channel. В plugin-режиме всегда включено через .mcp.json.
CLAUDEGRAM_CHANNEL_MODE=

# Allowlist sender_id'ов через запятую. Пустое = только себе.
# Только перечисленные ID смогут пушить сообщения в твою Claude-сессию.
TG_ALLOWED_SENDER_IDS=
