# Auto-detect text files and normalize line endings to LF on commit.
* text=auto eol=lf

# Explicitly text
*.py        text diff=python
*.md        text
*.toml      text
*.yml       text
*.yaml      text
*.json      text
*.sh        text eol=lf
*.lock      text -diff

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.session   binary

# Hide generated/lock files in PR diffs
uv.lock     linguist-generated=true
.coverage   linguist-generated=true
